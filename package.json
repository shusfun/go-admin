{
  "name": "go-admin",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "repo:build": "node -e \"console.log('repo-cli 使用源码直跑，无需构建。')\"",
    "repo": "node ./tools/repo-cli/src/index.mjs",
    "repo:test": "node --test tools/repo-cli/test/**/*.test.mjs",
    "repo:help": "pnpm run repo -- help",
    "repo:doctor": "pnpm run repo -- doctor",
    "repo:env": "pnpm run repo -- env",
    "repo:status": "pnpm run repo -- status",
    "repo:setup": "pnpm run repo -- setup",
    "repo:setup-status": "pnpm run repo -- setup-status",
    "repo:deps:backend": "pnpm run repo -- deps backend",
    "repo:deps:frontend": "pnpm run repo -- deps frontend",
    "repo:deps:all": "pnpm run repo -- deps all",
    "repo:build:backend": "pnpm run repo -- build backend",
    "repo:build:admin": "pnpm run repo -- build admin",
    "repo:build:mobile": "pnpm run repo -- build mobile",
    "repo:build:showcase": "pnpm run repo -- build showcase",
    "repo:build:frontend": "pnpm run repo -- build frontend",
    "repo:build:docker": "pnpm run repo -- build docker",
    "repo:build:all": "pnpm run repo -- build all",
    "repo:verify:frontend": "pnpm run repo -- verify frontend",
    "repo:verify:backend": "pnpm run repo -- verify backend",
    "repo:verify:all": "pnpm run repo -- verify all",
    "repo:infra:start": "pnpm run repo -- infra start",
    "repo:infra:stop": "pnpm run repo -- infra stop",
    "repo:infra:status": "pnpm run repo -- infra status",
    "repo:service:backend": "pnpm run repo -- service start backend",
    "repo:service:admin": "pnpm run repo -- service start admin",
    "repo:service:mobile": "pnpm run repo -- service start mobile",
    "repo:service:stop:all": "pnpm run repo -- service stop all",
    "repo:migrate": "pnpm run repo -- migrate",
    "repo:openapi": "pnpm run repo -- openapi",
    "repo:docker:up": "pnpm run repo -- docker-up",
    "repo:docker:down": "pnpm run repo -- docker-down",
    "repo:rename": "pnpm run repo -- rename",
    "repo:reinit": "pnpm run repo -- reinit --yes",
    "check:local-scrollbars": "node ./scripts/check-local-scrollbars.mjs",
    "dev:admin": "pnpm --filter @go-admin/admin-web dev",
    "dev:showcase": "pnpm --filter @go-admin/ui-showcase dev",
    "dev:mobile": "pnpm --filter @go-admin/mobile-h5 dev",
    "openapi": "orval --config frontend/orval.config.cjs",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "jsdom": "^27.0.1",
    "orval": "^7.11.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  }
}
